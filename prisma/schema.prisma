// HandbookBot — Prisma schema
// See PLAN.md for the full data model rationale.
//
// NOTE on pgvector: Prisma does not natively model the `vector` type, so the
// embedding column is declared as Unsupported("vector(1536)"). Reads/writes of
// the embedding (and similarity search) are done with raw SQL ($queryRaw /
// $executeRaw) — see src/lib/retrieval.ts. 1536 = dimensions of OpenAI's
// text-embedding-3-small model.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  verified         Boolean   @default(false)
  verificationCode String?
  resetCode        String?
  resetCodeExpires DateTime?
  createdAt        DateTime  @default(now())

  // stripe below
  subscriptionTier    String?   // null, 'starter', 'student', or 'business'
  stripeCustomerId    String?   @unique
  subscriptionStatus  String?   // 'active', 'canceled', 'past_due'
  messageCountMonth   Int       @default(0)
  messageCountResetAt DateTime  @default(now())

  bots Bot[]
}

model Bot {
  id        String   @id @default(cuid())
  name      String
  theme     String?
  slug             String?  @unique
  lockedOrigin     String?
  themeBackground  String?
  themeText        String?
  themeAccent      String?
  streamingEnabled Boolean @default(false)
  ownerId   String
  createdAt DateTime @default(now())

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  embedAttempts EmbedAttempt[]
  documents Document[]

  @@index([ownerId])
}

model Document {
  id        String   @id @default(cuid())
  filename  String
  content   String
  botId     String
  createdAt DateTime @default(now())

  bot    Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  @@index([botId])
}

model Chunk {
  id         String   @id @default(cuid())
  text       String
  embedding  Unsupported("vector(1536)")?
  documentId String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Layer 3 embed enforcement log. Records rejected embed attempts and
// localhost placeholder loads, so bot owners can see when their embed
// was blocked on other sites or previewed locally. Successful loads on
// the locked page are NOT logged — see PLAN.md for the "log rejections
// only" rationale.
model EmbedAttempt {
  id           String       @id @default(cuid())
  botId        String
  refererOrigin String?
  result       AttemptResult
  createdAt    DateTime     @default(now())

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
  @@index([botId, createdAt])
}

enum AttemptResult {
  WRONG_ORIGIN
  MISSING_REFERER
  INVALID_TOKEN
  MISSING_TOKEN
  LOCALHOST_PLACEHOLDER
}